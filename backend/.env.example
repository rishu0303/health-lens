PORT=5003
MONGO_URI=mongodb://127.0.0.1:27017/medinsight
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
GEMINI_API_KEY=replace-with-your-gemini-key
GEMINI_ANALYSIS_MODEL=gemini-3.1-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
MAX_UPLOAD_SIZE_MB=10

# RAG vector store
# Use "local" for persistent local JSON cache, or "pinecone" for Pinecone.
RAG_VECTOR_PROVIDER=local
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.65
RAG_AUTO_INDEX_ON_EMPTY=true
RAG_EMBEDDING_DIMENSIONS=768

# Required only when RAG_VECTOR_PROVIDER=pinecone
PINECONE_API_KEY=replace-with-your-pinecone-key
PINECONE_INDEX=your-index-name
PINECONE_HOST=https://your-index-host.svc.aped-4627-b74a.pinecone.io
PINECONE_INDEX_HOST=https://your-index-host.svc.aped-4627-b74a.pinecone.io
PINECONE_NAMESPACE=medinsight-knowledge-base
